<Window x:Class="WpfBowlingClub.Pages.ManufacturerDialogPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Производитель" 
        Height="220" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Название*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtName" Grid.Row="1" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Страна" FontWeight="Bold" Margin="0,30,0,44" Grid.RowSpan="3" Grid.Row="1"/>
        <TextBox x:Name="txtCountry" Grid.Row="3" Height="30" Margin="0,7,0,8"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35"
                    Background="#27AE60" Foreground="White"
                    Click="BtnSave_Click" Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35"
                    Background="#95A5A6" Foreground="White"
                    Click="BtnCancel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>