<Page x:Class="WpfBowlingClub.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы" 
      Background="#ECF0F1">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Фильтр по статусу" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbStatus" 
                          Width="200" 
                          Height="30"
                          SelectionChanged="CmbStatus_SelectionChanged">
                    <ComboBoxItem Content="Все заказы" IsSelected="True"/>
                    <ComboBoxItem Content="Новый"/>
                    <ComboBoxItem Content="В обработке"/>
                    <ComboBoxItem Content="Оплачен"/>
                    <ComboBoxItem Content="Завершен"/>
                    <ComboBoxItem Content="Отменен"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Таблица заказов - ВАЖНО: x:Name="dgOrders" -->
        <DataGrid x:Name="dgOrders" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  Background="White"
                  RowHeight="35"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заказа" 
                                    Binding="{Binding OrderNumber}" 
                                    Width="120"/>
                <DataGridTextColumn Header="Клиент" 
                                    Binding="{Binding User.LastName}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Дата" 
                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Сумма" 
                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" 
                                    Width="100"/>
                <DataGridTemplateColumn Header="Статус" 
                                        Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding Status}" 
                                      Width="100" 
                                      Height="25"
                                      SelectionChanged="OrderStatusChanged"
                                      Tag="{Binding}">
                                <ComboBoxItem Content="Новый" Tag="1"/>
                                <ComboBoxItem Content="В обработке" Tag="2"/>
                                <ComboBoxItem Content="Оплачен" Tag="3"/>
                                <ComboBoxItem Content="Завершен" Tag="4"/>
                                <ComboBoxItem Content="Отменен" Tag="5"/>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Инфо панель -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,10,0,0">
            <TextBlock x:Name="lblTotal" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Page>