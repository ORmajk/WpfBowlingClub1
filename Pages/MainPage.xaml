<Window x:Class="WpfBowlingClub.Pages.MainPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bowling Club Manager" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Height="100" Background="#1A252F">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="BOWLING" FontSize="20" FontWeight="Bold" 
                                   Foreground="White" TextAlignment="Center"/>
                        <TextBlock Text="CLUB MANAGER" FontSize="12" 
                                   Foreground="#BDC3C7" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="btnProducts" Content="📦 Товары" Height="45" 
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnProducts_Click"/>

                <Button x:Name="btnOrders" Content="📋 Заказы" Height="45" 
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnOrders_Click"/>

                <Button x:Name="btnSuppliers" Content="🏭 Поставщики" Height="45" 
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnSuppliers_Click"/>

                <Button x:Name="btnManufacturers" Content="🏷️ Производители" Height="45" 
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnManufacturers_Click"/>

                <Button x:Name="btnUsers" Content="👥 Пользователи" Height="45" 
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnUsers_Click" Visibility="Collapsed"/>

                <Button x:Name="btnLogout" Content="🚪 Выход" Height="45" Margin="0,50,0,0"
                        Background="#C0392B" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnLogout_Click"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Border Grid.Column="1" Background="#ECF0F1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>