<Page x:Class="WpfBowlingClub.Pages.ManufacturersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ManufacturersPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnAdd" Content="➕ Добавить" Width="120" Height="35"
                        Background="#27AE60" Foreground="White"
                        Click="BtnAdd_Click" Cursor="Hand"/>
                <Button x:Name="btnEdit" Content="✏️ Редактировать" Width="120" Height="35" Margin="10,0"
                        Background="#3498DB" Foreground="White"
                        Click="BtnEdit_Click" Cursor="Hand"/>
                <Button x:Name="btnDelete" Content="🗑️ Удалить" Width="120" Height="35"
                        Background="#E74C3C" Foreground="White"
                        Click="BtnDelete_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgManufacturers" Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  Background="White"
                  RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
