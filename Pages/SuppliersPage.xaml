<Page x:Class="WpfBowlingClub.Pages.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Поставщики" Background="#ECF0F1">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnAdd" 
                        Content="➕ Добавить" 
                        Width="120" Height="35"
                        Background="#27AE60" Foreground="White"
                        Click="BtnAdd_Click"
                        Cursor="Hand"/>

                <Button x:Name="btnEdit" 
                        Content="✏️ Редактировать" 
                        Width="120" Height="35" Margin="10,0"
                        Background="#3498DB" Foreground="White"
                        Click="BtnEdit_Click"
                        Cursor="Hand"/>

                <Button x:Name="btnDelete" 
                        Content="🗑️ Удалить" 
                        Width="120" Height="35"
                        Background="#E74C3C" Foreground="White"
                        Click="BtnDelete_Click"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Таблица поставщиков -->
        <DataGrid x:Name="dgSuppliers" Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Background="White"
                  RowHeight="35"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Контактная информация" Binding="{Binding ContactInfo}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>