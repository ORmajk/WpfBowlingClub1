<Window x:Class="WpfBowlingClub.Pages.UserDialogPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь" Height="690" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Фамилия -->
        <TextBlock Grid.Row="0" Text="Фамилия*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtLastName" Grid.Row="1" Height="30" Margin="0,0,0,15"/>

        <!-- Имя -->
        <TextBlock Grid.Row="2" Text="Имя*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtFirstName" Grid.Row="3" Height="30" Margin="0,0,0,15"/>

        <!-- Отчество -->
        <TextBlock Grid.Row="4" Text="Отчество" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtMiddleName" Grid.Row="5" Height="30" Margin="0,0,0,15"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="6" Text="Телефон*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPhone" Grid.Row="7" Height="30" Margin="0,0,0,15"/>

        <!-- Email -->
        <TextBlock Grid.Row="8" Text="Email*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtEmail" Grid.Row="9" Height="30" Margin="0,0,0,15"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="10" Text="Пароль*" FontWeight="Bold" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="11" Height="30" Margin="0,0,0,15"/>

        <!-- Роль -->
        <TextBlock Grid.Row="12" Text="Роль" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbRole" Grid.Row="13" Height="30" Margin="0,0,0,15"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Статус -->
        <TextBlock Grid.Row="14" Text="Статус" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="15" Height="30" Margin="0,0,0,15">
            <ComboBoxItem Content="Активен" Tag="1" IsSelected="True"/>
            <ComboBoxItem Content="Заблокирован" Tag="0"/>
        </ComboBox>

        <!-- Скидка -->
        <TextBlock Grid.Row="16" Text="Скидка (%)" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtDiscount" Grid.Row="17" Height="30" Margin="0,0,0,15" Text="0"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="19" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35"
                    Background="#27AE60" Foreground="White"
                    Click="BtnSave_Click" Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35"
                    Background="#95A5A6" Foreground="White"
                    Click="BtnCancel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>