<Page x:Class="WpfBowlingClub.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары" Background="#ECF0F1">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnAdd" 
                        Content="➕ Добавить" 
                        Width="120" Height="35"
                        Background="#27AE60" Foreground="White"
                        Click="BtnAdd_Click"
                        Cursor="Hand"/>

                <Button x:Name="btnEdit" 
                        Content="✏️ Редактировать" 
                        Width="120" Height="35" Margin="10,0"
                        Background="#3498DB" Foreground="White"
                        Click="BtnEdit_Click"
                        Cursor="Hand"/>

                <Button x:Name="btnDelete" 
                        Content="🗑️ Удалить" 
                        Width="120" Height="35"
                        Background="#E74C3C" Foreground="White"
                        Click="BtnDelete_Click"
                        Cursor="Hand"/>

                <Button x:Name="btnHistory" 
                        Content="📊 История цен" 
                        Width="120" Height="35" Margin="10,0"
                        Background="#F39C12" Foreground="White"
                        Click="BtnHistory_Click"
                        Cursor="Hand"/>

                <TextBox x:Name="txtSearch" 
                         Width="200" Height="35" Margin="20,0,0,0"
                         TextChanged="TxtSearch_TextChanged"/>
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Таблица товаров -->
        <DataGrid x:Name="dgProducts" Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Background="White"
                  RowHeight="40"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                <!-- ИСПРАВЛЕНО: правильный синтаксис StringFormat -->
                <DataGridTextColumn Header="Цена" 
                                    Binding="{Binding Price, StringFormat={}{0:N2} ₽}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="80"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier.Name}" Width="150"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.Name}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>