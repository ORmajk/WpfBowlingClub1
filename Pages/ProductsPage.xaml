<Page x:Class="WpfBowlingClub.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары" Background="#ECF0F1">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="➕ Добавить" Width="120" Height="35"
                    Background="#27AE60" Foreground="White" Click="BtnAdd_Click"/>
            <Button x:Name="btnEdit" Content="✏️ Изменить" Width="120" Height="35" Margin="10,0"
                    Background="#3498DB" Foreground="White" Click="BtnEdit_Click"/>
            <Button x:Name="btnDelete" Content="🗑️ Удалить" Width="120" Height="35"
                    Background="#E74C3C" Foreground="White" Click="BtnDelete_Click"/>
            <Button x:Name="btnHistory" Content="📊 История цен" Width="120" Height="35" Margin="10,0"
                    Background="#F39C12" Foreground="White" Click="BtnHistory_Click"/>

            <TextBox x:Name="txtSearch" Width="200" Height="35" Margin="20,0,0,0"
                     TextChanged="TxtSearch_TextChanged"/>
        </StackPanel>

        <!-- Таблица с картинками -->
        <DataGrid x:Name="dgProducts" Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  Background="White"
                  RowHeight="70">
            <DataGrid.Columns>
                <!-- Колонка с картинкой -->
                <DataGridTemplateColumn Header="Фото" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImageConverter}}" 
                                   Width="60" Height="60"
                                   Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="80"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="80"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier.Name}" Width="150"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.Name}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>