<Window x:Class="WpfBowlingClub.Pages.ProductDialogPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Артикул*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtArticle" Grid.Row="1" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Название*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtName" Grid.Row="3" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Цена*" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPrice" Grid.Row="5" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Количество" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtQuantity" Grid.Row="7" Height="30" Margin="0,0,0,15" Text="0"/>

        <TextBlock Text="Поставщик" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbSupplier" Grid.Row="9" Height="30" Margin="0,0,0,15"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <TextBlock Text="Производитель" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbManufacturer" Grid.Row="11" Height="30" Margin="0,0,0,15"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35"
                    Background="#27AE60" Foreground="White" Click="BtnSave_Click" Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35"
                    Background="#95A5A6" Foreground="White" Click="BtnCancel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>