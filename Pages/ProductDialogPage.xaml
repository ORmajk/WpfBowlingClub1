<Window x:Class="WpfBowlingClub.Pages.ProductDialogPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="635" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="10">
        <!-- Артикул -->
        <TextBlock Text="Артикул" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtArticle" Height="30" Margin="0,0,0,15"/>

        <!-- Название -->
        <TextBlock Text="Название" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtName" Height="30" Margin="0,0,0,15"/>

        <!-- Цена -->
        <TextBlock Text="Цена" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPrice" Height="30" Margin="0,0,0,15"/>

        <!-- Количество -->
        <TextBlock Text="Количество" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtQuantity" Height="30" Margin="0,0,0,15" Text="0"/>

        <!-- Поставщик -->
        <TextBlock Text="Поставщик" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbSupplier" Height="30" Margin="0,0,0,15"/>

        <!-- Производитель -->
        <TextBlock Text="Производитель" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbManufacturer" Height="30" Margin="0,0,0,15"/>

        <!-- Картинка (просто показываем путь) -->
        <TextBlock Text="Путь к картинке" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtImagePath" Height="30" Margin="0,0,0,15" IsReadOnly="True"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnLoadImage" Content="Выбрать картинку" Width="120" Height="30"
                    Click="BtnLoadImage_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnClearImage" Content="Очистить" Width="100" Height="30"
                    Click="BtnClearImage_Click"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35"
                    Background="#27AE60" Foreground="White" Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35"
                    Background="#95A5A6" Foreground="White" Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>